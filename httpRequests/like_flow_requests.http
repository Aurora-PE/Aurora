# You can use this file to easily send requests to your API.
# Prerequisite: humao.rest-client Vscode plugin
# TIP: Run requests in order - later requests reference IDs from earlier responses
# NOTE: Posts, comments, and follows must exist before testing likes and feed.

# ==========================================
# Setup - Create Users & Login
# ==========================================

### Create User1
# @name createUser1
POST http://localhost:8080/api/users
Content-Type: application/json

{
  "username": "likeuser1",
  "email": "likeuser1@example.com",
  "password": "securepassword123",
  "bio": "User 1",
  "isPrivate": false
}

### Create User2
# @name createUser2
POST http://localhost:8080/api/users
Content-Type: application/json

{
  "username": "likeuser2",
  "email": "likeuser2@example.com",
  "password": "securepassword456",
  "bio": "User 2",
  "isPrivate": false
}

### Create User3
# @name createUser3
POST http://localhost:8080/api/users
Content-Type: application/json

{
  "username": "likeuser3",
  "email": "likeuser3@example.com",
  "password": "securepassword789",
  "bio": "User 3",
  "isPrivate": false
}

### Login User1
# @name loginUser1
POST http://localhost:8080/api/users/login
Content-Type: application/json

{
  "email": "likeuser1@example.com",
  "password": "securepassword123"
}

### Login User2
# @name loginUser2
POST http://localhost:8080/api/users/login
Content-Type: application/json

{
  "email": "likeuser2@example.com",
  "password": "securepassword456"
}

### Login User3
# @name loginUser3
POST http://localhost:8080/api/users/login
Content-Type: application/json

{
  "email": "likeuser3@example.com",
  "password": "securepassword789"
}

# ==========================================
# Setup - Create Posts and Comments
# ==========================================

### Create Post by User1
# @name post1
POST http://localhost:8080/api/posts
Content-Type: application/json
Authorization: Bearer {{loginUser1.response.body.token}}

{
  "authorId": "{{createUser1.response.body.id}}",
  "content": "User1's public post",
  "imageUrl": "https://example.com/img1.png",
  "visibility": "PUBLIC"
}

### Create Private Post by User1
# @name post2
POST http://localhost:8080/api/posts
Content-Type: application/json
Authorization: Bearer {{loginUser1.response.body.token}}

{
  "authorId": "{{createUser1.response.body.id}}",
  "content": "User1's private post",
  "imageUrl": null,
  "visibility": "PRIVATE"
}

### Create Post by User2
# @name post3
POST http://localhost:8080/api/posts
Content-Type: application/json
Authorization: Bearer {{loginUser2.response.body.token}}

{
  "authorId": "{{createUser2.response.body.id}}",
  "content": "User2's public post",
  "imageUrl": null,
  "visibility": "PUBLIC"
}

### Create Comment on Post1
# @name comment1
POST http://localhost:8080/api/posts/{{post1.response.body.id}}/comments
Content-Type: application/json
Authorization: Bearer {{loginUser2.response.body.token}}

{
  "authorId": "{{createUser2.response.body.id}}",
  "content": "Nice post user1!"
}

### Create Second Comment on Post1
# @name comment2
POST http://localhost:8080/api/posts/{{post1.response.body.id}}/comments
Content-Type: application/json
Authorization: Bearer {{loginUser3.response.body.token}}

{
  "authorId": "{{createUser3.response.body.id}}",
  "content": "I agree!"
}


# ==========================================
# Like Posts
# ==========================================

### User2 Likes Post1 (SUCCESS)
POST http://localhost:8080/api/posts/{{post1.response.body.id}}/like?userId={{createUser2.response.body.id}}
Authorization: Bearer {{loginUser2.response.body.token}}

### User3 Likes Post1 (SUCCESS)
POST http://localhost:8080/api/posts/{{post1.response.body.id}}/like?userId={{createUser3.response.body.id}}
Authorization: Bearer {{loginUser3.response.body.token}}

### Verify Post1 likesCount is 2
GET http://localhost:8080/api/posts/{{post1.response.body.id}}
Authorization: Bearer {{loginUser1.response.body.token}}

### User2 Likes Post1 Again (SHOULD FAIL: 409 Conflict - duplicate like)
POST http://localhost:8080/api/posts/{{post1.response.body.id}}/like?userId={{createUser2.response.body.id}}
Authorization: Bearer {{loginUser2.response.body.token}}

### Like Non-Existent Post (SHOULD FAIL: 404 Not Found)
POST http://localhost:8080/api/posts/000000000000000000000000/like?userId={{createUser2.response.body.id}}
Authorization: Bearer {{loginUser2.response.body.token}}


# ==========================================
# Unlike Posts
# ==========================================

### User3 Unlikes Post1 (SUCCESS)
DELETE http://localhost:8080/api/posts/{{post1.response.body.id}}/unlike?userId={{createUser3.response.body.id}}
Authorization: Bearer {{loginUser3.response.body.token}}

### Verify Post1 likesCount is 1
GET http://localhost:8080/api/posts/{{post1.response.body.id}}
Authorization: Bearer {{loginUser1.response.body.token}}

### User3 Unlikes Post1 Again (SHOULD FAIL: 404 Not Found - like doesn't exist)
DELETE http://localhost:8080/api/posts/{{post1.response.body.id}}/unlike?userId={{createUser3.response.body.id}}
Authorization: Bearer {{loginUser3.response.body.token}}

### Unlike Non-Existent Post (SHOULD FAIL: 404 Not Found)
DELETE http://localhost:8080/api/posts/000000000000000000000000/unlike?userId={{createUser3.response.body.id}}
Authorization: Bearer {{loginUser3.response.body.token}}


# ==========================================
# Like Comments
# ==========================================

### User1 Likes Comment1 (SUCCESS)
POST http://localhost:8080/api/posts/{{post1.response.body.id}}/comments/{{comment1.response.body.id}}/like?userId={{createUser1.response.body.id}}
Authorization: Bearer {{loginUser1.response.body.token}}

### User3 Likes Comment1 (SUCCESS)
POST http://localhost:8080/api/posts/{{post1.response.body.id}}/comments/{{comment1.response.body.id}}/like?userId={{createUser3.response.body.id}}
Authorization: Bearer {{loginUser3.response.body.token}}

### Verify Comment1 likesCount is 2
GET http://localhost:8080/api/posts/{{post1.response.body.id}}/comments
Authorization: Bearer {{loginUser1.response.body.token}}

### User1 Likes Comment1 Again (SHOULD FAIL: 409 Conflict - duplicate like)
POST http://localhost:8080/api/posts/{{post1.response.body.id}}/comments/{{comment1.response.body.id}}/like?userId={{createUser1.response.body.id}}
Authorization: Bearer {{loginUser1.response.body.token}}

### Like Non-Existent Comment (SHOULD FAIL: 404 Not Found)
POST http://localhost:8080/api/posts/{{post1.response.body.id}}/comments/000000000000000000000000/like?userId={{createUser1.response.body.id}}
Authorization: Bearer {{loginUser1.response.body.token}}


# ==========================================
# Feed - Setup Follows
# ==========================================

### User3 Follows User1
POST http://localhost:8080/api/users/{{createUser1.response.body.id}}/follow
Authorization: Bearer {{loginUser3.response.body.token}}

### User3 Follows User2
POST http://localhost:8080/api/users/{{createUser2.response.body.id}}/follow
Authorization: Bearer {{loginUser3.response.body.token}}

### Get Feed for User3 (Should show PUBLIC posts from user1 and user2)
# Expected: post1 (PUBLIC, user1) and post3 (PUBLIC, user2)
# NOT expected: post2 (PRIVATE, user1 — user3 is not the author)
GET http://localhost:8080/api/users/{{createUser3.response.body.id}}/feed
Authorization: Bearer {{loginUser3.response.body.token}}

### Get Feed for User1 (No follows — should return empty array)
GET http://localhost:8080/api/users/{{createUser1.response.body.id}}/feed
Authorization: Bearer {{loginUser1.response.body.token}}


# ==========================================
# Cascade - Delete Post Removes Likes
# ==========================================

### Verify Post1 Still Has Likes and Comments
GET http://localhost:8080/api/posts/{{post1.response.body.id}}
Authorization: Bearer {{loginUser1.response.body.token}}

###
GET http://localhost:8080/api/posts/{{post1.response.body.id}}/comments
Authorization: Bearer {{loginUser1.response.body.token}}

### Delete Post1 (Should cascade delete comments and likes)
DELETE http://localhost:8080/api/posts/{{post1.response.body.id}}
Authorization: Bearer {{loginUser1.response.body.token}}

### Verify Post1 is Gone (SHOULD FAIL: 404 Not Found)
GET http://localhost:8080/api/posts/{{post1.response.body.id}}
Authorization: Bearer {{loginUser1.response.body.token}}

### Verify Comments are Gone (Should return empty array)
GET http://localhost:8080/api/posts/{{post1.response.body.id}}/comments
Authorization: Bearer {{loginUser1.response.body.token}}


# ==========================================
# Cleanup
# ==========================================

### Delete Post2
DELETE http://localhost:8080/api/posts/{{post2.response.body.id}}
Authorization: Bearer {{loginUser1.response.body.token}}

### Delete Post3
DELETE http://localhost:8080/api/posts/{{post3.response.body.id}}
Authorization: Bearer {{loginUser2.response.body.token}}

### Verify All Posts Deleted (Should return empty array)
GET http://localhost:8080/api/posts

### Delete User1
DELETE http://localhost:8080/api/users/self
Authorization: Bearer {{loginUser1.response.body.token}}

### Delete User2
DELETE http://localhost:8080/api/users/self
Authorization: Bearer {{loginUser2.response.body.token}}

### Delete User3
DELETE http://localhost:8080/api/users/self
Authorization: Bearer {{loginUser3.response.body.token}}