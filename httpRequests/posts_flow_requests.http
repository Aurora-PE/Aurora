# You can use this file to easily send requests to your API.
# Prerequisite: humao.rest-client Vscode plugin
# TIP: Run requests in order - later requests reference IDs from earlier responses

# ==========================================
# Setup - Create Users & Login
# ==========================================

### Create User1
# @name createUser1
POST http://localhost:8080/api/users
Content-Type: application/json

{
  "username": "postuser1",
  "email": "postuser1@example.com",
  "password": "securepassword123",
  "bio": "User 1",
  "isPrivate": false
}

### Create User2
# @name createUser2
POST http://localhost:8080/api/users
Content-Type: application/json

{
  "username": "postuser2",
  "email": "postuser2@example.com",
  "password": "securepassword456",
  "bio": "User 2",
  "isPrivate": false
}

### Login User1
# @name loginUser1
POST http://localhost:8080/api/users/login
Content-Type: application/json

{
  "email": "postuser1@example.com",
  "password": "securepassword123"
}

### Login User2
# @name loginUser2
POST http://localhost:8080/api/users/login
Content-Type: application/json

{
  "email": "postuser2@example.com",
  "password": "securepassword456"
}

# ==========================================
# Create Posts
# ==========================================

### Create First Post (PUBLIC)
# @name createPost1
POST http://localhost:8080/api/posts
Content-Type: application/json
Authorization: Bearer {{loginUser1.response.body.token}}

{
  "authorId": "{{createUser1.response.body.id}}",
  "content": "My first public post!",
  "imageUrl": "https://example.com/image1.png",
  "visibility": "PUBLIC"
}

### Create Second Post (PRIVATE, no image)
# @name createPost2
POST http://localhost:8080/api/posts
Content-Type: application/json
Authorization: Bearer {{loginUser1.response.body.token}}

{
  "authorId": "{{createUser1.response.body.id}}",
  "content": "This is a private thought",
  "imageUrl": null,
  "visibility": "PRIVATE"
}

### Create Third Post (PUBLIC, different author)
# @name createPost3
POST http://localhost:8080/api/posts
Content-Type: application/json
Authorization: Bearer {{loginUser2.response.body.token}}

{
  "authorId": "{{createUser2.response.body.id}}",
  "content": "Hello from user2!",
  "imageUrl": "https://example.com/image2.png",
  "visibility": "PUBLIC"
}


# ==========================================
# Read Posts
# ==========================================

### Get All Posts (Should return 3 posts)
GET http://localhost:8080/api/posts
Authorization: Bearer {{loginUser1.response.body.token}}

### Get First Post by ID (Should return post details)
GET http://localhost:8080/api/posts/{{createPost1.response.body.id}}
Authorization: Bearer {{loginUser1.response.body.token}}

### Get Non-Existent Post (SHOULD FAIL: 404 Not Found)
GET http://localhost:8080/api/posts/000000000000000000000000
Authorization: Bearer {{loginUser1.response.body.token}}


# ==========================================
# Update Posts
# ==========================================

### Update First Post Content and Visibility
PUT http://localhost:8080/api/posts/{{createPost1.response.body.id}}
Content-Type: application/json
Authorization: Bearer {{loginUser1.response.body.token}}

{
  "content": "Updated: My first post has been edited!",
  "imageUrl": "https://example.com/updated-image.png",
  "visibility": "PUBLIC"
}

### Update Second Post (Make it PUBLIC)
PUT http://localhost:8080/api/posts/{{createPost2.response.body.id}}
Content-Type: application/json
Authorization: Bearer {{loginUser1.response.body.token}}

{
  "content": "No longer private!",
  "imageUrl": null,
  "visibility": "PUBLIC"
}

### Update Non-Existent Post (SHOULD FAIL: 404 Not Found)
PUT http://localhost:8080/api/posts/000000000000000000000000
Content-Type: application/json
Authorization: Bearer {{loginUser1.response.body.token}}

{
  "content": "This should fail",
  "imageUrl": null,
  "visibility": "PUBLIC"
}

### Verify First Post Was Updated (Content should be changed)
GET http://localhost:8080/api/posts/{{createPost1.response.body.id}}
Authorization: Bearer {{loginUser1.response.body.token}}


# ==========================================
# Delete Posts
# ==========================================

### Delete Third Post (SUCCESS: 204 No Content)
DELETE http://localhost:8080/api/posts/{{createPost3.response.body.id}}
Authorization: Bearer {{loginUser2.response.body.token}}

### Verify Third Post Was Deleted (SHOULD FAIL: 404 Not Found)
GET http://localhost:8080/api/posts/{{createPost3.response.body.id}}
Authorization: Bearer {{loginUser2.response.body.token}}

### Delete Non-Existent Post (SHOULD FAIL: 404 Not Found)
DELETE http://localhost:8080/api/posts/000000000000000000000000
Authorization: Bearer {{loginUser1.response.body.token}}

### Get All Posts (Should return only 2 posts now)
GET http://localhost:8080/api/posts
Authorization: Bearer {{loginUser1.response.body.token}}


# ==========================================
# Cleanup
# ==========================================

### Delete First Post
DELETE http://localhost:8080/api/posts/{{createPost1.response.body.id}}
Authorization: Bearer {{loginUser1.response.body.token}}

### Delete Second Post
DELETE http://localhost:8080/api/posts/{{createPost2.response.body.id}}
Authorization: Bearer {{loginUser1.response.body.token}}

### Verify All Deleted (Should return empty array)
GET http://localhost:8080/api/posts
Authorization: Bearer {{loginUser1.response.body.token}}


### Delete User1
DELETE http://localhost:8080/api/users/self
Authorization: Bearer {{loginUser1.response.body.token}}

### Delete User2
DELETE http://localhost:8080/api/users/self
Authorization: Bearer {{loginUser2.response.body.token}}