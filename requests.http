# You can use this file to easily send requests to your API.
# Prerequisite: humao.rest-client Vscode plugin (already present on codespace)
# High-level overview of REST API concepts used here: https://www.packtpub.com/en-us/learning/how-to-tutorials/what-are-rest-verbs-and-status-codes-tutorial

# TIP: Run requests in order - later requests reference IDs from earlier responses


# ==========================================
# User Controller Endpoints
# ==========================================

### Create First User
# @name createUser1
POST http://localhost:8080/api/users
Content-Type: application/json

{
  "username": "johndoe",
  "email": "john@example.com",
  "password": "securepassword123",
  "bio": "Software Engineer",
  "avatarUrl": "https://example.com/avatar1.jpg"
}

### Create Second User
# @name createUser2
POST http://localhost:8080/api/users
Content-Type: application/json

{
  "username": "janedoe",
  "email": "jane@example.com",
  "password": "securepassword456",
  "bio": "Graphic Designer"
}

### Get User by ID (Public)
GET http://localhost:8080/api/users/{{createUser1.response.body.id}}

### Search User by Username (Public)
GET http://localhost:8080/api/users?username=j


# ==========================================
# Auth & Protected Endpoints
# ==========================================

### Login First User (Generates JWT)
# @name loginUser1
POST http://localhost:8080/api/users/login
Content-Type: application/json

{
  "email": "john@example.com",
  "password": "securepassword123"
}

### Login Second User (Generates JWT)
# @name loginUser2
POST http://localhost:8080/api/users/login
Content-Type: application/json

{
  "email": "jane@example.com",
  "password": "securepassword456"
}

### Update First User (SUCCESS: using their own token)
PUT http://localhost:8080/api/users/{{createUser1.response.body.id}}
Content-Type: application/json
Authorization: Bearer {{loginUser1.response.body.token}}

{
  "bio": "Senior Software Engineer",
  "avatarUrl": "https://example.com/new_avatar.jpg"
}

### Update Second User using First User's token (SHOULD FAIL with 401 Unauthorized)
PUT http://localhost:8080/api/users/{{createUser2.response.body.id}}
Content-Type: application/json
Authorization: Bearer {{loginUser1.response.body.token}}

{
  "bio": "I am hacking Jane's account"
}

### Delete First User (SUCCESS: using their own token)
DELETE http://localhost:8080/api/users/{{createUser1.response.body.id}}
Authorization: Bearer {{loginUser1.response.body.token}}

### Delete Second User (SUCCESS: using their own token)
DELETE http://localhost:8080/api/users/{{createUser2.response.body.id}}
Authorization: Bearer {{loginUser2.response.body.token}}